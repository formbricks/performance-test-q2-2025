  {
    "name": "medium-en-fr-feature-research",
    "size_bucket": "medium",
    "source_language": "English",
    "target_language": "French",
    "fields": [
      { "path": "welcomeCard.headline.default", "text": "Quick research on AI-assisted survey creation", "richText": false },
      { "path": "welcomeCard.html.default", "text": "<p>We're exploring features around <em>AI-assisted survey creation</em>. Your perspective will help us decide what's worth building.</p><p>This survey takes around <strong>4 minutes</strong>.</p>", "richText": true },
      { "path": "questions.0.headline.default", "text": "Have you used AI tools to help build surveys in the past?", "richText": false },
      { "path": "questions.0.choices.0", "text": "Yes, regularly", "richText": false },
      { "path": "questions.0.choices.1", "text": "Yes, occasionally", "richText": false },
      { "path": "questions.0.choices.2", "text": "I've tried it once or twice", "richText": false },
      { "path": "questions.0.choices.3", "text": "Never", "richText": false },
      { "path": "questions.1.headline.default", "text": "Which of these would be most valuable to you?", "richText": false },
      { "path": "questions.1.subheader.default", "text": "Rank from most to least valuable.", "richText": false },
      { "path": "questions.1.choices.0", "text": "Generating a survey draft from a short prompt", "richText": false },
      { "path": "questions.1.choices.1", "text": "Translating an existing survey into many languages", "richText": false },
      { "path": "questions.1.choices.2", "text": "Auto-summarizing free-text responses", "richText": false },
      { "path": "questions.1.choices.3", "text": "Auto-generating charts from your data", "richText": false },
      { "path": "questions.1.choices.4", "text": "Suggesting follow-up questions based on responses", "richText": false },
      { "path": "questions.2.headline.default", "text": "What concerns, if any, do you have about AI-generated survey content?", "richText": false },
      { "path": "questions.2.placeholder.default", "text": "Honesty welcome — privacy, accuracy, tone, anything else.", "richText": false },
      { "path": "questions.3.headline.default", "text": "Would you want to review AI output before it's saved?", "richText": false },
      { "path": "questions.3.html.default", "text": "<p>Reviewing means <strong>you</strong> approve every change before it goes live. Skipping review means the AI can act on its own within guardrails.</p>", "richText": true },
      { "path": "questions.4.headline.default", "text": "How important is it that AI features run inside your own infrastructure?", "richText": false },
      { "path": "questions.4.subheader.default", "text": "1 = not important, 5 = critical.", "richText": false },
      { "path": "questions.5.headline.default", "text": "Anything else you'd like us to know?", "richText": false },
      { "path": "questions.5.placeholder.default", "text": "Optional but appreciated.", "richText": false },
      { "path": "ending.headline.default", "text": "Thanks for the research input, {{firstName}}!", "richText": false }
    ]
  },
