      { "path": "questions.1.choices.5", "text": "Cross-team collaboration and shared workspaces", "richText": false },
      { "path": "questions.1.choices.6", "text": "Integrations with Slack, email, etc.", "richText": false },
      { "path": "questions.1.choices.7", "text": "Mobile or in-app surveys", "richText": false },
      { "path": "questions.2.headline.default", "text": "Were there features you tried but stopped using?", "richText": false },
      { "path": "questions.2.placeholder.default", "text": "Which ones, and what made you stop?", "richText": false },
