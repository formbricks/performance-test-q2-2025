      { "path": "questions.7.subheader.default", "text": "1 = poor fit, 5 = perfect fit.", "richText": false },
      { "path": "questions.8.headline.default", "text": "How well do our integrations cover the tools your team uses?", "richText": false },
      { "path": "questions.9.headline.default", "text": "How fairly priced does our product feel given the value you get?", "richText": false },
