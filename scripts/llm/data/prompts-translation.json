      { "path": "welcomeCard.headline.default", "text": "Quarterly product review", "richText": false },
      { "path": "welcomeCard.html.default", "text": "<p>Every quarter we ask power users for a deeper read on what's working and what isn't.</p><p>This survey is <strong>longer than usual</strong> — around 10 minutes. We promise we don't do this often.</p>", "richText": true },
